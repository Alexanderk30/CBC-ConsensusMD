# ConsensusMD environment variables
#
# Copy to .env and fill in real values:
#   cp .env.template .env
#
# .env is gitignored. Never commit real keys.

# Anthropic API key — used for the eliminative specialist (Claude
# Sonnet 4.6), the antagonist (Claude Opus 4.7), and the consensus
# agent (Claude Opus 4.7).
ANTHROPIC_API_KEY=

# OpenRouter API key — used for the probabilistic specialist (GPT-5.5)
# and the mechanistic specialist (Gemini 3.1 Pro Preview).
OPENROUTER_API_KEY=

# Optional model overrides. Leave blank to use the locked defaults.
# PROBABILISTIC_MODEL=openai/gpt-5.5
# MECHANISTIC_MODEL=google/gemini-3.1-pro-preview
# ELIMINATIVE_MODEL=claude-sonnet-4-6
# ANTAGONIST_MODEL=claude-opus-4-7
# CONSENSUS_MODEL=claude-opus-4-7
